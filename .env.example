PORT=3002
NODE_ENV=development
DATABASE_URL=postgres://media_user:mediapassword@localhost:15432/crm_database
DB_SCHEMA=schema_media
# Ruta local al archivo OCI config. Debe vivir fuera del repo o en una ruta
# propia del entorno del desarrollador.
OCI_CONFIG_FILE_PATH=
OCI_CONFIG_PROFILE=DEFAULT
OCI_REGION=
OCI_NAMESPACE=
OCI_BUCKET_AVATARS_PUBLIC=crm-avatars-public
OCI_BUCKET_DOCS_PRIVATE=crm-docs-private
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_SCAN_TIMEOUT_MS=90000
DOC_PAR_TTL_SECONDS=300
OCI_PAR_PRUNE_MAX=80
AVATAR_VERSIONS_TO_KEEP=3
GATEWAY_TRUST_SECRET=cima-local-gateway-trust-secret-do-not-use-production-2026
REDIS_URL=redis://127.0.0.1:16379
MEDIA_COMMANDS_STREAM_KEY=media:commands
MEDIA_RESPONSES_STREAM_KEY=media:responses
MEDIA_COMMANDS_CONSUMER_GROUP=media-command-consumers
