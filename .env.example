PORT=3002
NODE_ENV=development
DATABASE_URL=postgres://media_user:mediapassword@localhost:25432/crm_database
DB_SCHEMA=schema_media
# Ruta local al archivo OCI config. Debe vivir fuera del repo o en una ruta
# propia del entorno del desarrollador.
OCI_CONFIG_FILE_PATH=
OCI_CONFIG_PROFILE=DEFAULT
OCI_REGION=
OCI_NAMESPACE=
OCI_BUCKET_AVATARS_PUBLIC=crm-avatars-public
OCI_BUCKET_DOCS_PRIVATE=crm-docs-private
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_SCAN_TIMEOUT_MS=90000
DOC_PAR_TTL_SECONDS=300
OCI_PAR_PRUNE_MAX=80
AVATAR_VERSIONS_TO_KEEP=3
JWKS_URI=http://localhost:3000/.well-known/jwks.json
# Verificación de JWT de crm-collab
COLLAB_JWKS_URI=http://localhost:3001/.well-known/service-jwks.json
COLLAB_JWT_PUBLIC_KEY=
COLLAB_JWT_ISS=crm-collab
REDIS_URL=redis://127.0.0.1:16379
MEDIA_COMMANDS_STREAM_KEY=stream:collab.media-commands
MEDIA_RESPONSES_STREAM_KEY=stream:media.asset-responses
MEDIA_COMMANDS_CONSUMER_GROUP=group:media.commands
MEDIA_COMMANDS_DLQ_STREAM_KEY=stream:media.commands-dlq

# Rate limiting
RATE_LIMIT_MEDIA_AVATAR_MAX=10
RATE_LIMIT_MEDIA_AVATAR_WINDOW_MS=3600000
RATE_LIMIT_MEDIA_DOC_UPLOAD_MAX=40
RATE_LIMIT_MEDIA_DOC_UPLOAD_WINDOW_MS=900000
RATE_LIMIT_MEDIA_DOC_CONFIRM_MAX=40
RATE_LIMIT_MEDIA_DOC_CONFIRM_WINDOW_MS=900000

