{
  "name": "crm-media",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "description": "Media storage and access service for the CIMA CRM multi-repo platform.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "pnpm --prefix cima-contracts build && tsc",
    "start": "tsx src/server.ts",
    "oci:verify": "tsx src/scripts/verify-oci.ts",
    "pii:clean": "tsx src/scripts/pii-clean.ts",
    "worker:media-commands": "tsx src/workers/media-command.worker.ts",
    "worker:quarantine-scan": "tsx src/workers/quarantine-scan.worker.ts",
    "db:bootstrap": "tsx src/scripts/bootstrap.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "tsx src/scripts/ensure-db-schema.ts",
    "openapi:check": "node scripts/validate-openapi.mjs",
    "gateway:validate": "tsx scripts/validate-manifest.mjs",
    "test:contract": "hurl --test --variable base_url=http://localhost:28080 --variable WORKER_EMAIL=ana.martinez@cima.dev --variable WORKER_PASSWORD=Demo123! tests/01_media_gateway.hurl",
    "test:unit": "vitest run",
    "preinstall": "pnpm dlx only-allow pnpm"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SebasCarvajal11/crm-media.git"
  },
  "bugs": {
    "url": "https://github.com/SebasCarvajal11/crm-media/issues"
  },
  "homepage": "https://github.com/SebasCarvajal11/crm-media#readme",
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@sebascarvajal11/cima-contracts": "workspace:*",
    "clamscan": "^2.4.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-kit": "^0.31.10",
    "file-type": "^20.5.0",
    "hono": "^4.12.18",
    "ioredis": "^5.11.1",
    "oci-common": "^2.118.1",
    "oci-objectstorage": "^2.118.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "sharp": "^0.34.4",
    "tsx": "^4.21.0",
    "uuid": "^11.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/pg": "^8.20.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8",
    "yaml": "^2.7.0"
  }
}
